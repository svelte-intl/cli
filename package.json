{
    "name": "@svelte-i18n/cli",
    "version": "0.1.2",
    "description": "CLI tool for svelte-i18n",
    "type": "module",
    "bin": {
        "svelte-i18n": "./dist/index.js"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/svelte-intl/cli.git"
    },
    "main": "./dist/index.js",
    "files": [
        "dist"
    ],
    "scripts": {
        "build": "tsc",
        "dev": "tsx watch src/index.ts generate-types --input http://localhost:5173/api/locales/en --output ./.i18n/types.ts",
        "start": "node dist/index.js",
        "format": "prettier --write src",
        "format:check": "prettier --check src",
        "changeset": "changeset",
        "version": "changeset version",
        "release": "pnpm build && changeset publish"
    },
    "dependencies": {
        "commander": "^14.0.3",
        "zod": "^4.3.6"
    },
    "devDependencies": {
        "@changesets/cli": "^2.30.0",
        "@types/node": "^25.5.0",
        "prettier": "^3.8.1",
        "tsx": "^4.21.0",
        "typescript": "^5.9.3"
    },
    "engines": {
        "node": ">=22"
    },
    "license": "MIT",
    "pnpm": {
        "onlyBuiltDependencies": [
            "esbuild"
        ]
    }
}
